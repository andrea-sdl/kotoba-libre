{
  "manifest_version": 3,
  "name": "Kotoba Libre OpenID Callback Redirector",
  "version": "0.1.0",
  "description": "Redirect HTTPS OpenID callback pages into the kotobalibre:// app scheme in Firefox.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "webRequest",
    "webRequestBlocking"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "kotobalibre-openid-callback@kotobalibre.app",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "action": {
    "default_title": "Kotoba Libre Redirector",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
